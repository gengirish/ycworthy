# .env.local.example
# Copy this to .env.local and fill in your keys.
# NEVER commit .env.local — it's in .gitignore.

# ─── OpenRouter (NVIDIA Nemotron — primary provider) ──────────────────────────
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Optional model override (defaults to nvidia/llama-3.1-nemotron-ultra-253b-v1)
# OPENROUTER_NVIDIA_MODEL=nvidia/llama-3.1-nemotron-ultra-253b-v1

# ─── Google AI Studio (Gemini — automatic fallback) ───────────────────────────
# Get from: https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=AIza...

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
