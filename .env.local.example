# .env.local.example
# Copy this to .env.local and fill in your keys.
# NEVER commit .env.local — it's in .gitignore.

# ─── Google Gemini (PRIMARY — default provider) ──────────────────────────────
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...
# Optional model override (defaults to gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# ─── NVIDIA NIM (fallback, PREFERRED transport for Nemotron) ─────────────────
# Direct NVIDIA inference API. Free tier ~1000 requests/month with a personal key.
# Get from: https://build.nvidia.com/  →  click any model  →  "Get API Key"  (nvapi-...)
NVIDIA_NIM_API_KEY=nvapi-...
# Optional model override (defaults to nvidia/llama-3.1-nemotron-ultra-253b-v1)
# NVIDIA_NIM_MODEL=nvidia/llama-3.1-nemotron-ultra-253b-v1

# ─── OpenRouter (fallback transport for Nemotron — used only if NIM key absent)
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
# Optional model override (defaults to nvidia/llama-3.1-nemotron-ultra-253b-v1)
# OPENROUTER_NVIDIA_MODEL=nvidia/llama-3.1-nemotron-ultra-253b-v1

# ─── xAI Grok (tertiary fallback) ────────────────────────────────────────────
# Get from: https://console.x.ai/
XAI_API_KEY=xai-...
# Optional model override (defaults to grok-3-mini)
# GROK_MODEL=grok-3-mini
# Optional endpoint override (defaults to https://api.x.ai/v1/chat/completions)
# GROK_API_URL=https://api.x.ai/v1/chat/completions

# ─── Groq (optional transport for the same tertiary fallback slot) ───────────
# Key format starts with gsk_. Use this if you prefer Groq over xAI for the
# "grok" fallback leg.
# Get from: https://console.groq.com/keys
# GROQ_API_KEY=gsk_...
# Optional model override (defaults to llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile
# Optional endpoint override (defaults to https://api.groq.com/openai/v1/chat/completions)
# GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
